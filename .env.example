# Set this to the RETFound remote feature extractor URL if you have one.
# If left empty, the app will download the model weights from HuggingFace on first request.
RETFOUND_REMOTE_URL=

# HuggingFace repo for model weights (used if RETFOUND_REMOTE_URL is empty)
RETFOUND_HF_REPO_ID=
RETFOUND_HF_FILENAME=
ANTHROPIC_API_KEY=